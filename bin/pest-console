#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * pest-console — Custom Pest runner for pest-plugin-console.
 *
 * Key difference from vendor/bin/pest:
 *   When the plugin is active (no --no-console flag), COLLISION_PRINTER is
 *   intentionally NOT set before the Composer autoloader is loaded.
 *   This prevents NunoMaduro\Collision from registering its printer subscribers,
 *   giving pest-plugin-console full control over the output.
 *
 * Usage:
 *   vendor/bin/pest-console              → enhanced output (this plugin)
 *   vendor/bin/pest-console --no-console → original Pest/Collision output
 */

use Pest\Kernel;
use Pest\Panic;
use Pest\TestCaseFilters\GitDirtyTestCaseFilter;
use Pest\TestCaseMethodFilters\AssigneeTestCaseFilter;
use Pest\TestCaseMethodFilters\IssueTestCaseFilter;
use Pest\TestCaseMethodFilters\NotesTestCaseFilter;
use Pest\TestCaseMethodFilters\PrTestCaseFilter;
use Pest\TestCaseMethodFilters\TodoTestCaseFilter;
use Pest\TestSuite;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;

(static function (): void {
    $arguments         = $originalArguments = $_SERVER['argv'];
    $noConsole         = in_array('--no-console', $arguments, true);
    $dirty             = false;
    $todo              = false;
    $notes             = false;

    if ($noConsole) {
        // Restore original Pest behaviour: Collision printer registers normally.
        $_SERVER['COLLISION_PRINTER'] = 'DefaultPrinter';
    }
    // else: COLLISION_PRINTER is intentionally left unset.
    // When Collision's Autoload.php runs below, EnsurePrinterIsRegisteredSubscriber::register()
    // will find COLLISION_PRINTER absent and will be a no-op.

    foreach ($arguments as $key => $value) {
        if ($value === '--compact') {
            if ($noConsole) {
                $_SERVER['COLLISION_PRINTER_COMPACT'] = 'true';
            }
            unset($arguments[$key]);
        }

        if ($value === '--profile') {
            if ($noConsole) {
                $_SERVER['COLLISION_PRINTER_PROFILE'] = 'true';
            }
            unset($arguments[$key]);
        }

        if (str_contains($value, '--test-directory=')) {
            unset($arguments[$key]);
        } elseif ($value === '--test-directory') {
            unset($arguments[$key]);
            if (isset($arguments[$key + 1])) {
                unset($arguments[$key + 1]);
            }
        }

        if ($value === '--dirty') {
            $dirty = true;
            unset($arguments[$key]);
        }

        if ($value === '--todo') {
            $todo = true;
            unset($arguments[$key]);
        }

        if ($value === '--notes') {
            $notes = true;
            unset($arguments[$key]);
        }
    }

    if (! $noConsole) {
        // Suppress PHPUnit's built-in output; our plugin renders everything via addOutput().
        $arguments[] = '--no-output';
    }

    // Locate Composer's autoloader.
    $vendorPath = dirname(__DIR__, 4).'/vendor/autoload.php';
    $localPath  = dirname(__DIR__).'/vendor/autoload.php';

    if (file_exists($vendorPath)) {
        include_once $vendorPath;
        $autoloadPath = $vendorPath;
    } else {
        include_once $localPath;
        $autoloadPath = $localPath;
    }

    // At this point Collision's Autoload.php has run.
    // If COLLISION_PRINTER was unset, Collision's printer subscriber was NOT registered.

    $rootPath  = dirname($autoloadPath, 2);
    $input     = new ArgvInput();
    $testSuite = TestSuite::getInstance(
        $rootPath,
        $input->getParameterOption('--test-directory', 'tests'),
    );

    if ($dirty) {
        $testSuite->tests->addTestCaseFilter(new GitDirtyTestCaseFilter($rootPath));
    }
    if ($todo) {
        $testSuite->tests->addTestCaseMethodFilter(new TodoTestCaseFilter());
    }
    if ($notes) {
        $testSuite->tests->addTestCaseMethodFilter(new NotesTestCaseFilter());
    }
    if ($assignee = $input->getParameterOption('--assignee')) {
        $testSuite->tests->addTestCaseMethodFilter(new AssigneeTestCaseFilter((string) $assignee));
    }
    if ($issue = $input->getParameterOption('--issue')) {
        $testSuite->tests->addTestCaseMethodFilter(new IssueTestCaseFilter((int) $issue));
    }
    if ($pr = $input->getParameterOption('--pr')) {
        $testSuite->tests->addTestCaseMethodFilter(new PrTestCaseFilter((int) $pr));
    }

    $isDecorated = $input->getParameterOption('--colors', 'always') !== 'never';
    $output      = new ConsoleOutput(ConsoleOutput::VERBOSITY_NORMAL, $isDecorated);

    try {
        $kernel = Kernel::boot($testSuite, $input, $output);
        $result = $kernel->handle($originalArguments, $arguments);
        $kernel->terminate();
    } catch (Throwable $e) {
        Panic::with($e);
    }

    exit($result);
})();
